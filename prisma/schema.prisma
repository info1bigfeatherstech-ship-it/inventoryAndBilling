generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum GSTType {
  CGST_SGST
  IGST
  EXEMPT
}

enum BusinessType {
  RETAILER
  WHOLESALER
  IMPORTER
  EXPORTER
  DISTRIBUTOR
}

/// Immutable domain values — DB uses existing "SALES" value from initial migration.
enum MovementType {
  PURCHASE
  PURCHASE_RETURN
  WH_TO_SHOP
  SHOP_TO_SHOP
  WH_TO_WH
  SALES
  RETURN
  ADJUSTMENT
}

enum UserRole {
  SUPER_ADMIN
  WH_MANAGER
  WH_STOCK_LISTER
  SHOP_OWNER
  BILLING_STAFF
  SHOP_MANAGER
}

/// Channels used for analytics / bill attribution (BizPro-style).
enum SalesChannel {
  WALK_IN
  ONLINE
  WHOLESALE
  MHM
  OWB
  OTHER
}

enum ShopType {
  OWNER
  FRANCHISE
}

enum BillType {
  GST_INVOICE
  NON_GST_INVOICE
  ESTIMATE_INVOICE
  NON_LISTED_BILL
}

enum CustomerType {
  GST
  WALK_IN
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  CREDIT_ON_ACCOUNT
  CREDIT_NOTE_REDEMPTION
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  REFUNDED
  CANCELLED
}

/// Which master price was applied at sale time (BizPro bill line).
enum PriceType {
  MRP
  SPECIAL
  WHOLESALE
  RETAIL
  ONLINE
}

enum CreditNoteStatus {
  ACTIVE
  REDEEMED
  PARTIALLY_REDEEMED
  REFUNDED
  CANCELLED
}

enum DebitNoteType {
  SHORTAGE
  DEFECTIVE
  RATE_DIFFERENCE
  OTHER
}

enum DebitNoteStatus {
  ISSUED
  CANCELLED
}

enum PurchaseEntryStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum WarehouseExpenseCategory {
  RENT
  UTILITIES
  FREIGHT
  LABOUR
  TRANSPORT
  OFFICE
  REPAIRS
  OTHER
}

/// Shop petty-cash / operating expenses (repairs, utilities, stationery, etc.).
enum ShopExpenseCategory {
  RENT
  UTILITIES
  REPAIRS
  MAINTENANCE
  TRANSPORT
  OFFICE
  STATIONERY
  MEALS
  OTHER
}

enum VendorPaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum InwardStatus {
  SCHEDULED
  ARRIVED
  MAPPED
  CANCELLED
}

enum TransferBillType {
  GST_INVOICE
  NON_GST_INVOICE
  ESTIMATE_INVOICE
}

enum TransferRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  DISPATCHED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  COMPLETED
  CANCELLED
}

enum TransferRequestType {
  WH_TO_WH
  WH_TO_SHOP
  SHOP_TO_SHOP
}

enum TransferPriority {
  NORMAL
  HIGH
}

enum MediaStorageProvider {
  CLOUDINARY
  CLOUDFLARE_R2
}

// ==================== VENDOR MASTER ====================

model Vendor {
  vendor_id      String  @id @default(cuid())
  company_name   String
  contact_person String?
  phone          String  @unique
  whatsapp       String?
  email          String?
  gst_number     String?

  vendor_type   String?
  supply_city   String
  business_type BusinessType

  city       String
  /// 2-digit GST state code (e.g. "27" for Maharashtra) for POS / tax rules.
  state_code String?
  address    String?
  is_active  Boolean @default(true)
  remarks    String?

  products         Product[]
  purchase_entries PurchaseEntry[]
  debit_notes      DebitNote[]
  inward_receipts  InwardReceipt[]
  vendor_payments  VendorPayment[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("vendors")
}

// ==================== WAREHOUSE MASTER ====================

model Warehouse {
  warehouse_id   String  @id @default(cuid())
  warehouse_code String  @unique
  warehouse_name String
  address        String
  city           String
  manager_name   String?
  /// Optional — required only when approving franchise transfer GST bills from this warehouse.
  gstin          String?
  legal_name     String?
  /// 2-digit GST state code; may be derived from gstin when blank.
  state_code     String?
  is_active      Boolean @default(true)
  remarks        String?

  products          Product[]
  product_stocks    ProductStock[]
  purchase_entries PurchaseEntry[]
  debit_notes      DebitNote[]
  users           User[]
  inward_receipts InwardReceipt[]
  stock_ledger_out StockLedger[] @relation("LedgerFromWarehouse")
  stock_ledger_in  StockLedger[] @relation("LedgerToWarehouse")
  transfers_from       TransferRequest[] @relation("TransferFromWarehouse")
  transfers_to         TransferRequest[] @relation("TransferToWarehouse")
  bulk_transfers_from  BulkTransferRequest[] @relation("BulkTransferFromWarehouse")
  bulk_transfers_to    BulkTransferRequest[] @relation("BulkTransferToWarehouse")
  warehouse_expenses   WarehouseExpense[]
  vendor_payments      VendorPayment[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("warehouses")
}

// ==================== SHOP MASTER ====================
/// Sales office: billing identity, GST registrations, bank accounts for PDFs, staff assignment.

model Shop {
  shop_id    String @id @default(cuid())
  shop_code  String @unique
  shop_name  String
  address    String
  city       String
  pincode    String?
  /// 2-digit GST state code for intra/inter-state tax determination.
  state_code String?
  phone      String
  email      String?

  /// Primary business owner account (optional at creation; set after users exist).
  /// At most one shop may reference a user as owner (@unique).
  owner_user_id String? @unique
  owner         User?   @relation("ShopOwner", fields: [owner_user_id], references: [user_id], onDelete: SetNull)

  /// Reporting / bill tagging — empty array = not configured.
  sales_channels SalesChannel[] @default([])
  shop_type      ShopType @default(OWNER)

  is_active Boolean @default(true)
  remarks   String?

  gst_configs   ShopGstRegistration[]
  users         User[]                @relation("UserShopAssignment")
  shop_stocks   ShopStock[]
  bills         Bill[]
  /// Credit notes for returns processed at this shop.
  credit_notes_issued_here CreditNote[] @relation("CreditNoteReturnShop")
  /// Credit notes redeemed against a new sale at this shop.
  credit_notes_redeemed_here CreditNote[] @relation("CreditNoteRedeemedAtShop")
  credit_note_redemptions    CreditNoteRedemption[] @relation("CreditNoteRedemptionShop")

  stock_ledger_from StockLedger[] @relation("LedgerFromShop")
  stock_ledger_to   StockLedger[] @relation("LedgerToShop")
  transfers_from       TransferRequest[] @relation("TransferFromShop")
  transfers_to         TransferRequest[] @relation("TransferToShop")
  bulk_transfers_from  BulkTransferRequest[] @relation("BulkTransferFromShop")
  bulk_transfers_to    BulkTransferRequest[] @relation("BulkTransferToShop")
  product_levels       ShopProductLevel[]
  staff_codes          ShopStaffCode[]
  shop_expenses        ShopExpense[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([city])
  @@index([is_active])
  @@map("shops")
}

/// Counter staff identity for shared billing logins — code is stable; display_name can be reassigned.
model ShopStaffCode {
  staff_code_id String @id @default(cuid())
  shop_id       String

  /// Stable identifier printed on reports, e.g. SC001 (unique per shop).
  code         String
  display_name String
  phone        String?

  is_active Boolean @default(true)
  remarks   String?

  shop  Shop   @relation(fields: [shop_id], references: [shop_id], onDelete: Restrict)
  bills Bill[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([shop_id, code])
  @@index([shop_id, is_active])
  @@map("shop_staff_codes")
}

/// One row per GSTIN registered to a shop. Tax treatment (IGST vs CGST/SGST) follows
/// place-of-supply rules at transaction time — not duplicated here to avoid contradicting product master.
model ShopGstRegistration {
  gst_config_id String @id @default(cuid())
  shop_id       String

  /// 15-char GSTIN; validate format in application layer.
  gst_number String
  /// Trade / legal name as printed on invoice header for this registration.
  legal_name String?

  is_default Boolean @default(false)
  is_active  Boolean @default(true)

  effective_from DateTime?
  effective_to   DateTime?

  remarks String?

  shop          Shop          @relation(fields: [shop_id], references: [shop_id], onDelete: Restrict)
  bank_accounts ShopBankAccount[]
  bills         Bill[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([shop_id, gst_number])
  @@index([shop_id, is_active])
  @@map("shop_gst_registrations")
}

/// Bank details for invoice PDF dropdown; scoped to a GST registration (common in India).
model ShopBankAccount {
  bank_account_id String @id @default(cuid())
  gst_config_id   String

  account_holder_name String
  bank_name           String
  branch_name         String?
  account_number      String
  ifsc_code           String
  upi_id              String?

  is_default Boolean @default(false)
  is_active  Boolean @default(true)
  remarks    String?

  gst_config ShopGstRegistration @relation(fields: [gst_config_id], references: [gst_config_id], onDelete: Restrict)
  bills      Bill[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([gst_config_id, is_active])
  @@map("shop_bank_accounts")
}

// ==================== CATEGORY MASTER ====================

model Category {
  category_id String  @id @default(cuid())
  name        String  @unique
  description String?
  parent_id   String?
  is_active   Boolean @default(true)
  remarks     String?

  parent   Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [category_id])
  children Category[] @relation("CategoryHierarchy")

  products     Product[] @relation("ProductToCategory")
  sub_products Product[] @relation("ProductToSubCategory")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("categories")
}

// ==================== PRODUCT MASTER (warehouse-scoped parent) ====================

model Product {
  product_id   String @id @default(cuid())
  warehouse_id String
  product_code String
  name         String
  description  String?
  title        String?
  brand_name   String?

  primary_vendor_id String?

  hsn_code    String
  gst_percent Float
  gst_type    GSTType

  unit_of_measure String

  category_id     String?
  sub_category_id String?

  /// Default prices shared by variants; each variant may override its own prices.
  mrp             Float
  special_price   Float
  wholesale_price Float
  purchase_price  Float
  expenses        Float @default(0)
  /// e.g. "1 Year", "6 Months", "No Warranty"
  warranty        String?

  is_active Boolean @default(true)
  remarks   String?

  warehouse      Warehouse @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: Restrict)
  primary_vendor Vendor?   @relation(fields: [primary_vendor_id], references: [vendor_id])
  category       Category? @relation("ProductToCategory", fields: [category_id], references: [category_id])
  sub_category   Category? @relation("ProductToSubCategory", fields: [sub_category_id], references: [category_id])

  variants       ProductVariant[]
  product_stocks ProductStock[]
  purchase_items PurchaseItem[]
  stock_ledgers  StockLedger[]
  bill_lines     BillLineItem[]
  credit_lines   CreditNoteLineItem[]
  debit_note_lines DebitNoteLineItem[] @relation("DebitNoteLineProduct")
  inward_items   InwardReceiptItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([warehouse_id, product_code])
  @@index([warehouse_id, is_active])
  @@index([primary_vendor_id])
  @@index([category_id])
  @@index([is_active])
  @@map("products")
}

/// Purchasable SKU — barcode and prices live on the variant.
model ProductVariant {
  variant_id     String   @id @default(cuid())
  product_id     String
  product_code   String   // Full code like "6767-1"
  sku            String
  system_barcode String?
  vendor_barcode String?
  attributes     Json?
  
  mrp             Float
  special_price   Float
  wholesale_price Float
  purchase_price  Float
  expenses        Float @default(0)
  warranty        String?
  purchase_code   Int

  weight         Float?
  length         Float?
  width          Float?
  height         Float?
  
  low_stock_threshold Int @default(10)
  sort_order     Int    @default(0)
  is_default     Boolean @default(false)
  is_active      Boolean @default(true)
  remarks        String?
  
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  
  product        Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  images         ProductVariantImage[]
  stocks            ProductStock[]
  shop_stocks       ShopStock[]
  stock_ledgers     StockLedger[]
  transfer_requests   TransferRequest[]
  bulk_transfer_items BulkTransferRequestItem[]
  shop_product_levels ShopProductLevel[]
  bill_lines          BillLineItem[] @relation("BillLineVariant")
  credit_note_lines   CreditNoteLineItem[]
  debit_note_lines    DebitNoteLineItem[] @relation("DebitNoteLineVariant")
  purchase_items      PurchaseItem[]
  inward_items_mapped InwardReceiptItem[] @relation("InwardMappedVariant")

  @@unique([product_id, sku])
  @@unique([product_id, product_code])
  @@index([purchase_code])
}

model ProductVariantImage {
  image_id         String               @id @default(cuid())
  variant_id       String
  url              String
  storage_key      String
  storage_provider MediaStorageProvider @default(CLOUDINARY)
  alt_text         String?
  sort_order       Int                  @default(0)

  variant ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([variant_id, sort_order])
  @@map("product_variant_images")
}

// ==================== WAREHOUSE STOCK (location + batch) ====================
/// batch_number: use "" for non-batch aggregate rows so @@unique(product_id, warehouse_id, batch_number) is stable in PostgreSQL.

model ProductStock {
  stock_id String @id @default(cuid())

  variant_id   String
  product_id   String
  warehouse_id String

  quantity Int @default(0)

  low_stock_threshold Int?

  room_zone  String
  rack_shelf String
  position   String?

  batch_number String  @default("")
  expiry_date  DateTime?

  last_purchase_id   String?
  last_purchase_date DateTime?

  remarks String?

  variant       ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Restrict)
  product       Product        @relation(fields: [product_id], references: [product_id])
  warehouse     Warehouse      @relation(fields: [warehouse_id], references: [warehouse_id])
  last_purchase PurchaseEntry? @relation("LastPurchase", fields: [last_purchase_id], references: [purchase_id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([variant_id, warehouse_id, batch_number])
  @@index([warehouse_id, product_id])
  @@index([warehouse_id, variant_id])
  @@map("product_stocks")
}

// ==================== SHOP STOCK (available / reserved / in-transit) ====================
/// Operational balances per shop for billing and transfers. Mutations must go through services + ledger.

model ShopStock {
  shop_stock_id String @id @default(cuid())
  shop_id       String
  variant_id    String

  quantity_available  Int @default(0)
  quantity_reserved   Int @default(0)
  quantity_in_transit Int @default(0)
  low_stock_threshold Int @default(5)

  shop    Shop           @relation(fields: [shop_id], references: [shop_id], onDelete: Restrict)
  variant ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Restrict)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([shop_id, variant_id])
  @@index([shop_id, quantity_available])
  @@index([variant_id])
  @@map("shop_stocks")
}

// ==================== PURCHASE ====================

model PurchaseEntry {
  purchase_id     String @id @default(cuid())
  purchase_number String @unique

  vendor_id         String
  vendor_invoice_no String @unique
  warehouse_id      String

  purchase_date DateTime @default(now())

  status PurchaseEntryStatus @default(RECEIVED)

  subtotal     Float
  tax_amount   Float
  total_amount Float

  received_by String
  received_at DateTime @default(now())

  remarks String?

  vendor          Vendor          @relation(fields: [vendor_id], references: [vendor_id])
  warehouse       Warehouse       @relation(fields: [warehouse_id], references: [warehouse_id])
  items           PurchaseItem[]
  debit_notes           DebitNote[]
  product_stocks        ProductStock[]  @relation("LastPurchase")
  receivedByUser        User            @relation("PurchaseReceivedBy", fields: [received_by], references: [user_id])
  payment_allocations   VendorPaymentAllocation[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([warehouse_id, purchase_date])
  @@map("purchase_entries")
}

model WarehouseExpense {
  expense_id     String @id @default(cuid())
  expense_number String @unique

  warehouse_id String
  category     WarehouseExpenseCategory
  description  String
  amount       Float

  expense_date   DateTime
  payment_method PaymentMethod?
  reference_no   String?

  recorded_by_user_id String
  remarks             String?

  is_cancelled         Boolean   @default(false)
  cancelled_at         DateTime?
  cancelled_by_user_id String?

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: Restrict)
  recorded_by  User      @relation("WarehouseExpenseRecordedBy", fields: [recorded_by_user_id], references: [user_id])
  cancelled_by User?     @relation("WarehouseExpenseCancelledBy", fields: [cancelled_by_user_id], references: [user_id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([warehouse_id, expense_date])
  @@index([category])
  @@map("warehouse_expenses")
}

model ShopExpense {
  expense_id     String @id @default(cuid())
  expense_number String @unique

  shop_id    String
  category   ShopExpenseCategory
  description String
  amount     Float

  expense_date   DateTime
  payment_method PaymentMethod?
  reference_no   String?

  recorded_by_user_id String
  remarks             String?

  is_cancelled         Boolean   @default(false)
  cancelled_at         DateTime?
  cancelled_by_user_id String?

  shop         Shop  @relation(fields: [shop_id], references: [shop_id], onDelete: Restrict)
  recorded_by  User  @relation("ShopExpenseRecordedBy", fields: [recorded_by_user_id], references: [user_id])
  cancelled_by User? @relation("ShopExpenseCancelledBy", fields: [cancelled_by_user_id], references: [user_id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([shop_id, expense_date])
  @@index([category])
  @@map("shop_expenses")
}

model VendorPayment {
  payment_id     String @id @default(cuid())
  payment_number String @unique

  vendor_id      String
  warehouse_id   String
  amount         Float
  payment_method PaymentMethod
  reference_no   String?
  payment_date   DateTime @default(now())
  status         VendorPaymentStatus @default(PAID)

  paid_by_user_id String
  remarks         String?

  is_cancelled         Boolean   @default(false)
  cancelled_at         DateTime?
  cancelled_by_user_id String?

  vendor       Vendor    @relation(fields: [vendor_id], references: [vendor_id], onDelete: Restrict)
  warehouse    Warehouse @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: Restrict)
  paid_by      User      @relation("VendorPaymentPaidBy", fields: [paid_by_user_id], references: [user_id])
  cancelled_by User?     @relation("VendorPaymentCancelledBy", fields: [cancelled_by_user_id], references: [user_id], onDelete: SetNull)
  allocations  VendorPaymentAllocation[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([warehouse_id, payment_date])
  @@index([vendor_id, payment_date])
  @@index([status])
  @@map("vendor_payments")
}

model VendorPaymentAllocation {
  allocation_id    String @id @default(cuid())
  payment_id       String
  purchase_id      String
  allocated_amount Float

  payment  VendorPayment @relation(fields: [payment_id], references: [payment_id], onDelete: Cascade)
  purchase PurchaseEntry @relation(fields: [purchase_id], references: [purchase_id], onDelete: Restrict)

  @@unique([payment_id, purchase_id])
  @@index([purchase_id])
  @@map("vendor_payment_allocations")
}

model PurchaseItem {
  purchase_item_id String @id @default(cuid())
  purchase_id      String
  product_id       String

  quantity      Int
  purchase_cost Float

  batch_number String?
  expiry_date  DateTime?

  room_zone  String
  rack_shelf String
  position   String?

  remarks String?

  /// Snapshot from mapped variant at GRN (for audit).
  variant_id    String?
  line_subtotal Float   @default(0)
  gst_percent   Float   @default(0)
  tax_amount    Float   @default(0)

  purchase PurchaseEntry  @relation(fields: [purchase_id], references: [purchase_id])
  product  Product        @relation(fields: [product_id], references: [product_id])
  variant  ProductVariant? @relation(fields: [variant_id], references: [variant_id], onDelete: SetNull)
  debit_note_lines DebitNoteLineItem[]

  @@index([purchase_id])
  @@index([variant_id])
  @@map("purchase_items")
}

// ==================== DEBIT NOTES (WH → Vendor) ====================

model DebitNote {
  debit_note_id     String @id @default(cuid())
  debit_note_number String @unique

  original_purchase_id String
  warehouse_id         String
  vendor_id            String

  type         DebitNoteType
  subtotal     Float
  gst_amount   Float
  debit_amount Float

  /// When true, stock was deducted from warehouse (defective return to vendor).
  return_stock Boolean @default(false)
  status       DebitNoteStatus @default(ISSUED)

  created_by_user_id String
  remarks            String?

  original_purchase PurchaseEntry @relation(fields: [original_purchase_id], references: [purchase_id], onDelete: Restrict)
  warehouse         Warehouse     @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: Restrict)
  vendor            Vendor        @relation(fields: [vendor_id], references: [vendor_id], onDelete: Restrict)
  created_by        User          @relation("DebitNoteCreatedBy", fields: [created_by_user_id], references: [user_id])

  lines DebitNoteLineItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([warehouse_id, created_at])
  @@index([vendor_id, created_at])
  @@index([original_purchase_id])
  @@index([status])
  @@map("debit_notes")
}

model DebitNoteLineItem {
  line_id        String @id @default(cuid())
  debit_note_id  String
  purchase_item_id String
  variant_id     String
  product_id     String

  quantity    Int
  unit_cost   Float
  gst_percent Float
  line_subtotal Float
  tax_amount    Float
  line_total    Float

  /// Snapshot for stock deduction (matches purchase GRN batch).
  batch_number String?

  debit_note    DebitNote      @relation(fields: [debit_note_id], references: [debit_note_id], onDelete: Cascade)
  purchase_item PurchaseItem   @relation(fields: [purchase_item_id], references: [purchase_item_id], onDelete: Restrict)
  variant       ProductVariant @relation("DebitNoteLineVariant", fields: [variant_id], references: [variant_id])
  product       Product        @relation("DebitNoteLineProduct", fields: [product_id], references: [product_id])

  @@index([debit_note_id])
  @@index([purchase_item_id])
  @@index([variant_id])
  @@map("debit_note_line_items")
}

// ==================== STOCK LEDGER ====================

model StockLedger {
  ledger_id  String @id @default(cuid())
  product_id String
  variant_id String?

  movement_type MovementType
  quantity      Int

  from_warehouse_id String?
  to_warehouse_id   String?
  from_shop_id      String?
  to_shop_id        String?

  reference_id   String?
  reference_type String?

  batch_number String?
  expiry_date  DateTime?

  /// Landed unit cost at movement time (purchase_price + expenses snapshot).
  unit_cost  Float?
  line_value Float?

  created_by String
  remarks    String?

  created_at DateTime @default(now())

  product        Product         @relation(fields: [product_id], references: [product_id])
  variant        ProductVariant? @relation(fields: [variant_id], references: [variant_id], onDelete: SetNull)
  from_warehouse Warehouse?      @relation("LedgerFromWarehouse", fields: [from_warehouse_id], references: [warehouse_id])
  to_warehouse   Warehouse?      @relation("LedgerToWarehouse", fields: [to_warehouse_id], references: [warehouse_id])
  from_shop      Shop?           @relation("LedgerFromShop", fields: [from_shop_id], references: [shop_id])
  to_shop        Shop?           @relation("LedgerToShop", fields: [to_shop_id], references: [shop_id])
  createdByUser  User            @relation("StockLedgerCreatedBy", fields: [created_by], references: [user_id])

  @@index([product_id, created_at])
  @@index([variant_id, created_at])
  @@index([from_shop_id, created_at])
  @@index([to_shop_id, created_at])
  @@index([from_warehouse_id, created_at])
  @@index([movement_type, created_at])
  @@index([reference_id, reference_type])
  @@map("stock_ledger")
}

// ==================== CUSTOMER MASTER ====================

model Customer {
  customer_id   String       @id @default(cuid())
  mobile          String       @unique
  name            String
  email           String?
  is_gst_registered Boolean  @default(false)
  company_name    String?
  gst_number      String?
  address         String?
  city            String?
  state_code      String?
  pincode         String?

  total_spent   Float     @default(0)
  total_orders  Int       @default(0)
  last_purchase DateTime?
  loyalty_tier  String?

  credit_limit   Float?
  credit_balance Float    @default(0)
  credit_used    Float    @default(0)

  is_active Boolean @default(true)
  remarks   String?

  bills        Bill[]
  credit_notes CreditNote[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([mobile])
  @@index([loyalty_tier])
  @@index([state_code])
  @@map("customers")
}

// ==================== BILLING ====================
/// Bills are immutable after posting except controlled cancellation flags (audit).

model Bill {
  bill_id     String @id @default(cuid())
  bill_number String @unique
  shop_id     String
  customer_id String?

  bill_type BillType @default(GST_INVOICE)

  customer_mobile String?
  customer_name   String?
  customer_gstin  String?
  place_of_supply_state_code String?

  subtotal       Float @default(0)
  discount       Float @default(0)
  taxable_amount Float @default(0)
  gst_amount     Float @default(0)
  total_amount   Float @default(0)

  payment_status PaymentStatus  @default(PENDING)
  payment_method PaymentMethod?
  paid_amount    Float          @default(0)
  balance_amount Float          @default(0)

  gst_config_id   String?
  bank_account_id String?

  sales_channel SalesChannel? @default(WALK_IN)

  pdf_storage_key String?

  is_cancelled         Boolean   @default(false)
  cancelled_at         DateTime?
  cancelled_by_user_id String?
  cancel_reason        String?

  created_by_user_id String

  /// Snapshot at bill time — preserved when staff code is reassigned to another person.
  staff_code_id       String?
  staff_code_value    String?
  staff_name_snapshot String?

  shop         Shop                 @relation(fields: [shop_id], references: [shop_id], onDelete: Restrict)
  staff_code   ShopStaffCode?       @relation(fields: [staff_code_id], references: [staff_code_id], onDelete: SetNull)
  customer     Customer?            @relation(fields: [customer_id], references: [customer_id], onDelete: SetNull)
  gst_config   ShopGstRegistration? @relation(fields: [gst_config_id], references: [gst_config_id], onDelete: SetNull)
  bank_account ShopBankAccount?     @relation(fields: [bank_account_id], references: [bank_account_id], onDelete: SetNull)
  created_by   User                 @relation("BillCreatedBy", fields: [created_by_user_id], references: [user_id])

  items        BillLineItem[]
  payments     BillPayment[]
  credit_notes_from          CreditNote[] @relation("CreditNoteOriginalBill")
  credit_notes_redeemed_here CreditNote[] @relation("CreditNoteRedeemedOnBill")
  credit_note_redemptions    CreditNoteRedemption[] @relation("BillCreditNoteRedemptions")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([shop_id, created_at])
  @@index([customer_id])
  @@index([customer_mobile])
  @@index([bill_number])
  @@index([is_cancelled])
  @@index([payment_status])
  @@index([shop_id, staff_code_value, created_at])
  @@map("bills")
}

model BillLineItem {
  line_id    String @id @default(cuid())
  bill_id    String
  /// Null for NON_LISTED_BILL items (manually entered, not linked to inventory)
  variant_id String?
  /// Null for NON_LISTED_BILL items
  product_id String?
  /// Manually entered product name — set only for NON_LISTED_BILL items
  manual_item_name String?

  quantity   Int
  price_type PriceType @default(RETAIL)
  unit_price Float
  /// MRP at time of sale (from variant.mrp or manually entered) for invoice display.
  mrp_unit_price Float?

  gst_percent    Float  @default(0)
  gst_type       GSTType @default(CGST_SGST)
  hsn_code       String @default("")
  line_subtotal  Float
  discount       Float @default(0)
  taxable_amount Float
  tax_amount     Float
  line_total     Float

  bill    Bill            @relation(fields: [bill_id], references: [bill_id], onDelete: Cascade)
  variant ProductVariant? @relation("BillLineVariant", fields: [variant_id], references: [variant_id])
  product Product?        @relation(fields: [product_id], references: [product_id])

  created_at DateTime @default(now())

  @@index([bill_id])
  @@index([variant_id])
  @@map("bill_line_items")
}

model BillPayment {
  payment_id     String        @id @default(cuid())
  bill_id        String
  amount         Float
  payment_method PaymentMethod
  reference_no   String?
  paid_at        DateTime      @default(now())
  collected_by   String

  bill      Bill @relation(fields: [bill_id], references: [bill_id], onDelete: Cascade)
  collector User @relation("BillPaymentCollector", fields: [collected_by], references: [user_id])

  @@index([bill_id])
  @@map("bill_payments")
}

// ==================== CREDIT NOTES ====================

model CreditNote {
  credit_note_id     String @id @default(cuid())
  credit_note_number String @unique

  original_bill_id String
  shop_id          String
  customer_id      String?

  customer_mobile String
  customer_name   String?

  subtotal     Float
  gst_amount   Float
  credit_amount Float

  amount_redeemed Float @default(0)
  amount_refunded Float @default(0)

  status CreditNoteStatus @default(ACTIVE)

  redeemed_at               DateTime?
  redeemed_at_shop_id       String?
  redeemed_against_bill_id  String?

  refunded_at           DateTime?
  refund_method         PaymentMethod?
  refund_reference_no   String?
  refunded_by_user_id   String?

  photo_storage_key String?

  created_by_user_id String
  remarks            String?

  shop           Shop      @relation("CreditNoteReturnShop", fields: [shop_id], references: [shop_id], onDelete: Restrict)
  customer       Customer? @relation(fields: [customer_id], references: [customer_id], onDelete: SetNull)
  original_bill  Bill      @relation("CreditNoteOriginalBill", fields: [original_bill_id], references: [bill_id], onDelete: Restrict)
  redeemed_at_shop Shop? @relation("CreditNoteRedeemedAtShop", fields: [redeemed_at_shop_id], references: [shop_id], onDelete: SetNull)
  redeemed_against_bill Bill? @relation("CreditNoteRedeemedOnBill", fields: [redeemed_against_bill_id], references: [bill_id], onDelete: SetNull)
  created_by     User    @relation("CreditNoteCreatedBy", fields: [created_by_user_id], references: [user_id])
  refunded_by    User?   @relation("CreditNoteRefundedBy", fields: [refunded_by_user_id], references: [user_id], onDelete: SetNull)

  lines        CreditNoteLineItem[]
  redemptions  CreditNoteRedemption[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([shop_id, status])
  @@index([customer_mobile])
  @@map("credit_notes")
}

/// Per-use ledger when a credit note is applied (supports cross-shop partial redemptions).
model CreditNoteRedemption {
  redemption_id       String   @id @default(cuid())
  credit_note_id      String
  amount              Float
  redeemed_at_shop_id String
  against_bill_id     String?
  redeemed_by_user_id String
  redeemed_at         DateTime @default(now())

  credit_note      CreditNote @relation(fields: [credit_note_id], references: [credit_note_id], onDelete: Cascade)
  redeemed_at_shop Shop       @relation("CreditNoteRedemptionShop", fields: [redeemed_at_shop_id], references: [shop_id], onDelete: Restrict)
  against_bill     Bill?      @relation("BillCreditNoteRedemptions", fields: [against_bill_id], references: [bill_id], onDelete: SetNull)
  redeemed_by      User       @relation("CreditNoteRedemptionBy", fields: [redeemed_by_user_id], references: [user_id])

  @@index([credit_note_id, redeemed_at])
  @@index([redeemed_at_shop_id])
  @@map("credit_note_redemptions")
}

model CreditNoteLineItem {
  line_id        String @id @default(cuid())
  credit_note_id String
  variant_id     String
  product_id     String

  quantity    Int
  unit_price  Float
  gst_percent Float
  line_subtotal Float
  tax_amount    Float
  line_total    Float

  credit_note CreditNote     @relation(fields: [credit_note_id], references: [credit_note_id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variant_id], references: [variant_id])
  product     Product        @relation(fields: [product_id], references: [product_id])

  @@index([credit_note_id])
  @@index([variant_id])
  @@map("credit_note_line_items")
}

// ==================== USER ====================
model User {
  user_id       String   @id @default(cuid())
  name          String
  phone         String   @unique
  password_hash String?
  role          UserRole

  warehouse_id String?
  shop_id      String?

  is_active Boolean @default(true)
  remarks   String?

  warehouse Warehouse? @relation(fields: [warehouse_id], references: [warehouse_id])
  shop      Shop?      @relation("UserShopAssignment", fields: [shop_id], references: [shop_id], onDelete: SetNull)

  owned_shop Shop? @relation("ShopOwner")

  purchase_entries_received PurchaseEntry[] @relation("PurchaseReceivedBy")
  stock_ledgers_created     StockLedger[]   @relation("StockLedgerCreatedBy")
  bills_created             Bill[]          @relation("BillCreatedBy")
  bill_payments_collected   BillPayment[]   @relation("BillPaymentCollector")
  credit_notes_created      CreditNote[]    @relation("CreditNoteCreatedBy")
  credit_notes_refunded     CreditNote[]    @relation("CreditNoteRefundedBy")
  debit_notes_created       DebitNote[]     @relation("DebitNoteCreatedBy")
  warehouse_expenses_recorded  WarehouseExpense[] @relation("WarehouseExpenseRecordedBy")
  warehouse_expenses_cancelled WarehouseExpense[] @relation("WarehouseExpenseCancelledBy")
  shop_expenses_recorded       ShopExpense[]      @relation("ShopExpenseRecordedBy")
  shop_expenses_cancelled      ShopExpense[]      @relation("ShopExpenseCancelledBy")
  vendor_payments_paid         VendorPayment[] @relation("VendorPaymentPaidBy")
  vendor_payments_cancelled    VendorPayment[] @relation("VendorPaymentCancelledBy")
  credit_note_redemptions   CreditNoteRedemption[] @relation("CreditNoteRedemptionBy")
  refresh_tokens            RefreshToken[]
  inward_receipts_created   InwardReceipt[] @relation("InwardCreatedBy")
  inward_receipts_received  InwardReceipt[] @relation("InwardReceivedBy")
  transfer_requests_created TransferRequest[] @relation("TransferRequester")
  transfer_requests_approved TransferRequest[] @relation("TransferApprover")
  transfer_requests_dispatched TransferRequest[] @relation("TransferDispatcher")
  transfer_requests_received TransferRequest[] @relation("TransferReceiver")
  transfer_requests_cancelled TransferRequest[] @relation("TransferCanceller")
  bulk_requests_created       BulkTransferRequest[] @relation("BulkTransferRequester")
  bulk_requests_approved      BulkTransferRequest[] @relation("BulkTransferApprover")
  bulk_requests_dispatched    BulkTransferRequest[] @relation("BulkTransferDispatcher")
  bulk_requests_received      BulkTransferRequest[] @relation("BulkTransferReceiver")
  bulk_requests_cancelled     BulkTransferRequest[] @relation("BulkTransferCanceller")

  google_drive_token   UserGoogleDriveToken?
  backup_settings      BackupClientSettings?
  backup_records       BackupRecord[]
  backup_restore_logs  BackupRestoreLog[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([shop_id])
  @@index([warehouse_id])
  @@index([role, is_active])
  @@map("users")
}

// ==================== SHOP MIN-MAX LEVELS ====================

model ShopProductLevel {
  level_id    String @id @default(cuid())
  shop_id     String
  variant_id  String

  min_level   Int
  max_level   Int
  reorder_qty Int?

  is_active Boolean @default(true)

  shop    Shop           @relation(fields: [shop_id], references: [shop_id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variant_id], references: [variant_id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([shop_id, variant_id])
  @@index([shop_id, is_active])
  @@map("shop_product_levels")
}

// ==================== BULK TRANSFER REQUESTS ====================

model BulkTransferRequest {
  bulk_request_id     String @id @default(cuid())
  bulk_request_number String @unique

  request_type      TransferRequestType @default(WH_TO_SHOP)
  from_warehouse_id String?
  from_shop_id      String?
  to_shop_id        String?
  to_warehouse_id   String?

  status TransferRequestStatus @default(REQUESTED)

  requested_by    String
  requested_at    DateTime @default(now())
  request_remarks String?

  approved_by      String?
  approved_at      DateTime?
  rejection_reason String?

  dispatched_by     String?
  dispatched_at     DateTime?
  tracking_number   String?
  expected_delivery DateTime?

  received_by     String?
  received_at     DateTime?
  receive_remarks String?

  cancelled_by  String?
  cancelled_at  DateTime?
  cancel_reason String?

  transfer_bill_type         TransferBillType?
  transfer_bill_number       String?           @unique
  transfer_bill_generated_at DateTime?

  items BulkTransferRequestItem[]

  from_warehouse Warehouse? @relation("BulkTransferFromWarehouse", fields: [from_warehouse_id], references: [warehouse_id])
  from_shop      Shop?      @relation("BulkTransferFromShop", fields: [from_shop_id], references: [shop_id])
  to_shop        Shop?      @relation("BulkTransferToShop", fields: [to_shop_id], references: [shop_id], onDelete: Restrict)
  to_warehouse   Warehouse? @relation("BulkTransferToWarehouse", fields: [to_warehouse_id], references: [warehouse_id])
  requester      User       @relation("BulkTransferRequester", fields: [requested_by], references: [user_id])
  approver       User?      @relation("BulkTransferApprover", fields: [approved_by], references: [user_id])
  dispatcher     User?      @relation("BulkTransferDispatcher", fields: [dispatched_by], references: [user_id])
  receiver       User?      @relation("BulkTransferReceiver", fields: [received_by], references: [user_id])
  canceller      User?      @relation("BulkTransferCanceller", fields: [cancelled_by], references: [user_id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([request_type])
  @@index([to_shop_id, status])
  @@index([to_warehouse_id, status])
  @@index([requested_by])
  @@map("bulk_transfer_requests")
}

model BulkTransferRequestItem {
  bulk_item_id    String @id @default(cuid())
  bulk_request_id String
  variant_id      String
  quantity        Int
  /// Original qty requested by shop — never changed after create.
  requested_quantity Int?
  batch_number    String?

  is_approved       Boolean @default(true)
  approved_quantity Int?
  rejection_reason  String?

  received_quantity Int @default(0)

  /// Snapshotted at dispatch from variant landed cost.
  unit_cost_snapshot  Float?
  line_value_snapshot Float?

  /// Franchise shop transfers — snapshotted at dispatch.
  franchise_markup_percent_snapshot Float?
  franchise_mrp_snapshot            Float?
  franchise_unit_price_snapshot     Float?
  franchise_line_value_snapshot     Float?

  bulk_request BulkTransferRequest @relation(fields: [bulk_request_id], references: [bulk_request_id], onDelete: Cascade)
  variant      ProductVariant      @relation(fields: [variant_id], references: [variant_id])

  @@index([bulk_request_id])
  @@index([variant_id])
  @@map("bulk_transfer_request_items")
}

// ==================== STOCK TRANSFER REQUESTS (workflow) ====================

model TransferRequest {
  request_id     String @id @default(cuid())
  request_number String @unique
  request_type   TransferRequestType

  from_warehouse_id String?
  to_warehouse_id   String?
  from_shop_id      String?
  to_shop_id        String?

  variant_id   String
  quantity     Int
  batch_number String?

  priority TransferPriority @default(NORMAL)

  status TransferRequestStatus @default(REQUESTED)

  requested_by    String
  requested_at    DateTime @default(now())
  request_remarks String?

  approved_by      String?
  approved_at      DateTime?
  rejection_reason String?

  dispatched_by     String?
  dispatched_at     DateTime?
  tracking_number   String?
  expected_delivery DateTime?

  received_by       String?
  received_at       DateTime?
  received_quantity Int?
  receive_remarks   String?

  cancelled_by  String?
  cancelled_at  DateTime?
  cancel_reason String?

  transfer_bill_type         TransferBillType?
  transfer_bill_number       String?           @unique
  transfer_bill_generated_at DateTime?

  /// Snapshotted at dispatch (unit landed cost × dispatch qty).
  unit_cost_snapshot  Float?
  line_value_snapshot Float?

  /// Franchise shop transfers — snapshotted at dispatch (not stored on product master).
  franchise_markup_percent_snapshot Float?
  franchise_mrp_snapshot            Float?
  franchise_unit_price_snapshot     Float?
  franchise_line_value_snapshot     Float?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  from_warehouse Warehouse?     @relation("TransferFromWarehouse", fields: [from_warehouse_id], references: [warehouse_id])
  to_warehouse   Warehouse?     @relation("TransferToWarehouse", fields: [to_warehouse_id], references: [warehouse_id])
  from_shop      Shop?          @relation("TransferFromShop", fields: [from_shop_id], references: [shop_id])
  to_shop        Shop?          @relation("TransferToShop", fields: [to_shop_id], references: [shop_id])
  variant        ProductVariant @relation(fields: [variant_id], references: [variant_id])
  requester      User           @relation("TransferRequester", fields: [requested_by], references: [user_id])
  approver       User?          @relation("TransferApprover", fields: [approved_by], references: [user_id])
  dispatcher     User?          @relation("TransferDispatcher", fields: [dispatched_by], references: [user_id])
  receiver       User?          @relation("TransferReceiver", fields: [received_by], references: [user_id])
  canceller      User?          @relation("TransferCanceller", fields: [cancelled_by], references: [user_id])

  @@index([status])
  @@index([request_type])
  @@index([from_warehouse_id, status])
  @@index([to_shop_id, status])
  @@index([requested_by])
  @@index([created_at])
  @@map("transfer_requests")
}

model RefreshToken {
  refresh_token_id String   @id @default(cuid())
  user_id          String
  token_jti        String   @unique
  token_hash       String
  expires_at       DateTime
  revoked_at       DateTime?
  revoked_reason   String?
  replaced_by_jti  String?
  last_used_at     DateTime?
  ip_address       String?
  user_agent       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, revoked_at])
  @@index([user_id, expires_at])
  @@index([expires_at])
  @@map("refresh_tokens")
}

model InwardReceipt {
  inward_id           String       @id @default(cuid())
  inward_number       String       @unique
  vendor_id           String
  warehouse_id        String
  status              InwardStatus @default(SCHEDULED)
  expected_date       DateTime?
  arrived_at          DateTime?
  vendor_invoice_no   String?
  challan_no          String?
  transport_details   String?
  created_by_user_id  String
  received_by_user_id String?
  remarks             String?

  vendor      Vendor    @relation(fields: [vendor_id], references: [vendor_id], onDelete: Restrict)
  warehouse   Warehouse @relation(fields: [warehouse_id], references: [warehouse_id], onDelete: Restrict)
  created_by  User      @relation("InwardCreatedBy", fields: [created_by_user_id], references: [user_id], onDelete: Restrict)
  received_by User?     @relation("InwardReceivedBy", fields: [received_by_user_id], references: [user_id], onDelete: SetNull)
  items       InwardReceiptItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vendor_id, expected_date])
  @@index([warehouse_id, status, expected_date])
  @@index([status, created_at])
  @@map("inward_receipts")
}

model InwardReceiptItem {
  inward_item_id    String   @id @default(cuid())
  inward_id         String
  line_no           Int
  item_name         String
  variant_text      String?
  quantity_received Int
  purchase_cost     Float?
  batch_number      String?
  expiry_date       DateTime?
  room_zone         String?
  rack_shelf        String?
  position          String?
  mapped_product_id String?
  /// SKU-level mapping: which variant receives stock on MAPPED.
  mapped_variant_id String?
  remarks           String?

  inward_receipt InwardReceipt @relation(fields: [inward_id], references: [inward_id], onDelete: Cascade)
  mapped_product Product?      @relation(fields: [mapped_product_id], references: [product_id], onDelete: SetNull)
  mapped_variant ProductVariant? @relation("InwardMappedVariant", fields: [mapped_variant_id], references: [variant_id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([inward_id, line_no])
  @@index([mapped_product_id])
  @@index([mapped_variant_id])
  @@map("inward_receipt_items")
}

// ==================== BACKUP & GOOGLE DRIVE ====================

enum BackupType {
  AUTO
  MANUAL_COMPUTER
  MANUAL_DRIVE
}

enum BackupStatus {
  IN_PROGRESS
  SUCCESS
  FAILED
}

enum BackupRestoreMode {
  MERGE
  REPLACE
  MISSING_ONLY
}

enum BackupStorageLocation {
  LOCAL
  GOOGLE_DRIVE
}

model UserGoogleDriveToken {
  token_id           String   @id @default(cuid())
  user_id            String   @unique
  access_token       String
  refresh_token      String?
  expires_at         DateTime
  google_email       String?
  google_account_id  String?
  scopes             String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_google_drive_tokens")
}

/// Org-wide application settings (singleton row id = "default").
model AppSettings {
  id                       String   @id @default("default")
  /// Allowed values: 20, 40, 60 — markup on (purchase_price + expenses) for franchise transfer pricing.
  franchise_markup_percent Int      @default(40)
  /// GST issuer details for franchise transfer GST invoices (warehouse → franchise shop).
  transfer_invoice_gstin       String?
  transfer_invoice_legal_name  String?
  transfer_invoice_state_code  String?
  transfer_invoice_address     String?
  transfer_invoice_city        String?
  transfer_invoice_phone       String?
  updated_by               String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@map("app_settings")
}

model BackupClientSettings {
  setting_id              String  @id @default(cuid())
  user_id                 String  @unique
  auto_backup_enabled     Boolean @default(false)
  auto_backup_frequency   String  @default("DAILY")
  auto_backup_time        String  @default("02:00")
  retention_days          Int     @default(30)
  auto_delete_old_backups Boolean @default(true)
  email_on_success        Boolean @default(false)
  email_on_failure        Boolean @default(true)
  email_on_late           Boolean @default(false)
  include_bills           Boolean @default(true)
  include_customers       Boolean @default(true)
  include_products        Boolean @default(true)
  include_stock           Boolean @default(true)
  include_staff_codes     Boolean @default(true)
  include_settings        Boolean @default(true)
  compression_level       String  @default("NORMAL")
  encrypt_backup          Boolean @default(false)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("backup_client_settings")
}

model BackupRecord {
  backup_id            String                @id @default(cuid())
  display_id           String
  user_id              String
  backup_type          BackupType
  status               BackupStatus          @default(IN_PROGRESS)
  filename             String
  file_size_bytes      BigInt?
  duration_ms          Int?
  storage_location     BackupStorageLocation
  google_drive_file_id String?
  scope_role           UserRole
  scope_json           Json?
  error_message        String?
  created_at           DateTime              @default(now())
  completed_at         DateTime?

  user          User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  restore_logs  BackupRestoreLog[]

  @@unique([user_id, display_id])
  @@index([user_id, created_at])
  @@index([user_id, status])
  @@map("backup_records")
}

model BackupRestoreLog {
  restore_id       String            @id @default(cuid())
  user_id          String
  backup_id        String?
  source_filename  String
  restore_mode     BackupRestoreMode
  status           BackupStatus      @default(IN_PROGRESS)
  summary_json     Json?
  error_message    String?
  created_at       DateTime          @default(now())
  completed_at     DateTime?

  user   User          @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  backup BackupRecord? @relation(fields: [backup_id], references: [backup_id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@map("backup_restore_logs")
}
