        {
          "name": "Create Warehouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('warehouse_id', jsonData.data.warehouse_id);",
                  "    pm.test('Warehouse created successfully', function () {",
                  "        pm.expect(pm.response.code).to.equal(201);",
                  "        pm.expect(jsonData.success).to.be.true;",
                  "        pm.expect(jsonData.data.warehouse_code).to.exist;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"warehouse_code\": \"WH-CHN-001\",\n  \"warehouse_name\": \"Chennai Main Warehouse\",\n  \"address\": \"123 Industrial Park, Sriperambur\",\n  \"city\": \"Chennai\",\n  \"manager_name\": \"John Doe\",\n  \"remarks\": \"Primary warehouse for Tamil Nadu\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/warehouses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "warehouses"
              ]
            },
            "description": "Create a new warehouse.\n\n**Authentication:** Required (SUPER_ADMIN role)\n\n**Request Body:**\n- `warehouse_code` (string, required): Unique warehouse code (3-20 chars, [A-Z, 0-9, _, -])\n- `warehouse_name` (string, required): Name of warehouse (2-150 chars)\n- `address` (string, required): Physical address (3-500 chars)\n- `city` (string, required): City name (2-100 chars)\n- `manager_name` (string, optional): Manager name (2-100 chars)\n- `remarks` (string, optional): Additional remarks (max 500 chars)\n\n**Response:** 201 Created with warehouse object"
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"warehouse_code\": \"WH-CHN-001\",\n  \"warehouse_name\": \"Chennai Main Warehouse\",\n  \"address\": \"123 Industrial Park, Sriperambur\",\n  \"city\": \"Chennai\",\n  \"manager_name\": \"John Doe\",\n  \"remarks\": \"Primary warehouse for Tamil Nadu\"\n}"
                },
